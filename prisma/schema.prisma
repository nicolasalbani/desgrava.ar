generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

// ─── NextAuth Models ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  ingestToken   String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  arcaCredential   ArcaCredential?
  invoices         Invoice[]
  automationJobs   AutomationJob[]
  preference       UserPreference?
  yearPreferences  UserYearPreference[]
  emailIngestLogs  EmailIngestLog[]
  familyDependents FamilyDependent[]
  employers        Employer[]
  personalData     PersonalData[]
  domesticWorkers  DomesticWorker[]
  domesticReceipts DomesticReceipt[]
  presentaciones   Presentacion[]
  subscription     Subscription?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── ARCA Credentials ──────────────────────────────────────────

model ArcaCredential {
  id             String   @id @default(cuid())
  userId         String   @unique
  cuit           String // XX-XXXXXXXX-X
  encryptedClave String
  iv             String
  authTag        String
  isValidated    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Invoices ──────────────────────────────────────────────────

model Invoice {
  id                String            @id @default(cuid())
  userId            String
  deductionCategory DeductionCategory
  providerCuit      String
  providerName      String?
  invoiceType       InvoiceType
  invoiceNumber     String? // "XXXXX-YYYYYYYY" (punto de venta + comp. nro)
  invoiceDate       DateTime? // Date printed on the invoice
  amount            Decimal           @db.Decimal(12, 2)
  fiscalYear        Int
  fiscalMonth       Int // 1-12
  description       String?
  contractStartDate DateTime? // For ALQUILER_VIVIENDA: lease contract start date (Vigencia Desde)
  contractEndDate   DateTime? // For ALQUILER_VIVIENDA: lease contract end date (Vigencia Hasta)
  source            InvoiceSource     @default(MANUAL)
  ocrConfidence     Float? // 0-1 for OCR-sourced
  siradiqStatus     SiradiqStatus     @default(PENDING)
  originalFilename  String?
  fileData          Bytes?
  fileMimeType      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  familyDependentId String?

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyDependent FamilyDependent? @relation(fields: [familyDependentId], references: [id], onDelete: SetNull)
  automationJobs  AutomationJob[]

  @@index([userId, fiscalYear])
  @@index([userId, siradiqStatus])
}

// ─── Automation Jobs ───────────────────────────────────────────

model AutomationJob {
  id                String        @id @default(cuid())
  userId            String
  invoiceId         String?
  familyDependentId String?
  jobType           JobType
  status            JobStatus     @default(PENDING)
  attempts          Int           @default(0)
  maxAttempts       Int           @default(3)
  logs              Json          @default("[]")
  screenshotUrl     String?
  errorMessage      String?
  resultData        Json?
  currentStep       String?
  fiscalYear        Int?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice          Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  familyDependent  FamilyDependent? @relation("AutomationJobFamilyDependent", fields: [familyDependentId], references: [id], onDelete: SetNull)
  employerId       String?
  employer         Employer?        @relation("AutomationJobEmployer", fields: [employerId], references: [id], onDelete: SetNull)
  domesticReceipts DomesticReceipt[]
  presentacion     Presentacion?    @relation(fields: [presentacionId], references: [id], onDelete: SetNull)
  presentacionId   String?

  @@index([userId, status])
}

// ─── User Preferences ──────────────────────────────────────────

model UserPreference {
  id                String  @id @default(cuid())
  userId            String  @unique
  defaultFiscalYear   Int?
  notifications       Boolean @default(true)
  autoSubmitEnabled   Boolean @default(false)
  autoSubmitDay       Int? // 1-28, day of month for automatic presentación
  skippedArcaDialogs  String[] @default([])

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserYearPreference {
  id           String  @id @default(cuid())
  userId       String
  fiscalYear   Int
  ownsProperty Boolean @default(false) // true = Beneficio 10% (Art. 85 inc. k), false = Beneficio 40% (Art. 85 inc. h)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fiscalYear])
}

// ─── Enums ─────────────────────────────────────────────────────

enum DeductionCategory {
  CUOTAS_MEDICO_ASISTENCIALES
  PRIMAS_SEGURO_MUERTE
  PRIMAS_AHORRO_SEGUROS_MIXTOS
  APORTES_RETIRO_PRIVADO
  DONACIONES
  INTERESES_HIPOTECARIOS
  GASTOS_SEPELIO
  GASTOS_MEDICOS
  GASTOS_INDUMENTARIA_TRABAJO
  ALQUILER_VIVIENDA
  SERVICIO_DOMESTICO
  APORTE_SGR
  VEHICULOS_CORREDORES
  INTERESES_CORREDORES
  GASTOS_EDUCATIVOS
  OTRAS_DEDUCCIONES
  NO_DEDUCIBLE
}

enum InvoiceType {
  FACTURA_A
  FACTURA_B
  FACTURA_C
  NOTA_DEBITO_A
  NOTA_DEBITO_B
  NOTA_DEBITO_C
  NOTA_CREDITO_A
  NOTA_CREDITO_B
  NOTA_CREDITO_C
  RECIBO
  TICKET
}

enum InvoiceSource {
  MANUAL
  PDF
  OCR
  EMAIL
  ARCA
}

enum SiradiqStatus {
  PENDING
  QUEUED
  PROCESSING
  PREVIEW_READY
  CONFIRMED
  SUBMITTED
  FAILED
}

enum JobType {
  VALIDATE_CREDENTIALS
  SUBMIT_INVOICE
  BULK_SUBMIT
  PULL_FAMILY_DEPENDENTS
  PUSH_FAMILY_DEPENDENTS
  PULL_COMPROBANTES
  PULL_DOMESTIC_WORKERS
  PULL_DOMESTIC_RECEIPTS
  SUBMIT_DOMESTIC_DEDUCTION
  PULL_PRESENTACIONES
  SUBMIT_PRESENTACION
  PULL_EMPLOYERS
  PUSH_EMPLOYERS
  PULL_PERSONAL_DATA
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ─── Cargas de Familia ───────────────────────────────────────

model FamilyDependent {
  id              String   @id @default(cuid())
  userId          String
  fiscalYear      Int      @default(2025)
  tipoDoc         String   // CUIT | CUIL | CDI | DNI | LC | LE
  numeroDoc       String
  apellido        String
  nombre          String
  fechaNacimiento String?  // dd/mm/yyyy
  parentesco      String   // "1"=Cónyuge, "3"=Hijo<18, "30"=Hijastro<18, "31"=Hijo incapacitado, "32"=Hijastro incapacitado, "51"=Unión convivencial
  fechaUnion      String?  // dd/mm/yyyy — for parentesco 1 or 51
  porcentajeDed   String?  // "50" or "100" — for hijos/hijastros
  cuitOtroDed     String?  // CUIL/CUIT of the other parent when porcentajeDed=50
  familiaCargo    Boolean  @default(true)
  residente       Boolean  @default(true)
  tieneIngresos   Boolean  @default(false)
  montoIngresos   Decimal? @db.Decimal(12, 2)
  mesDesde        Int      @default(1)
  mesHasta        Int      @default(12)
  proximosPeriodos Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices       Invoice[]
  automationJobs AutomationJob[] @relation("AutomationJobFamilyDependent")

  @@index([userId, fiscalYear])
}

// ─── Employers ──────────────────────────────────────────────

model Employer {
  id               String   @id @default(cuid())
  userId           String
  fiscalYear       Int
  cuit             String   // 11-digit employer CUIT
  razonSocial      String
  fechaInicio      String   // dd/mm/yyyy
  fechaFin         String?  // dd/mm/yyyy — null if still employed
  agenteRetencion  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  automationJobs AutomationJob[] @relation("AutomationJobEmployer")

  @@index([userId, fiscalYear])
}

// ─── Personal Data ──────────────────────────────────────────

model PersonalData {
  id             String   @id @default(cuid())
  userId         String
  fiscalYear     Int
  apellido       String
  nombre         String
  dirCalle       String
  dirNro         String
  dirPiso        String?
  dirDpto        String?
  descProvincia  String
  localidad      String
  codPostal      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fiscalYear])
}

// ─── Email Ingest ────────────────────────────────────────────

model EmailIngestLog {
  id              String             @id @default(cuid())
  userId          String?
  emailId         String
  fromAddress     String
  toAddress       String
  subject         String?
  status          EmailIngestStatus  @default(RECEIVED)
  attachmentCount Int                @default(0)
  invoicesCreated Int                @default(0)
  errorMessage    String?
  createdAt       DateTime           @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([emailId])
}

enum EmailIngestStatus {
  RECEIVED
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
  REJECTED
}

// ─── Provider Catalog (global) ──────────────────────────────

model ProviderCatalog {
  id                String            @id @default(cuid())
  cuit              String            @unique
  razonSocial       String?
  deductionCategory DeductionCategory
  source            CatalogSource     @default(AI_INVOICE)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

enum CatalogSource {
  AI_PDF
  AI_WEB_LOOKUP
  AI_INVOICE
  MANUAL
}

// ─── Personal de Casas Particulares ─────────────────────────

model DomesticWorker {
  id                   String   @id @default(cuid())
  userId               String
  fiscalYear           Int
  cuil                 String // 11 digits, no dashes
  apellidoNombre       String // Full name as shown in ARCA
  tipoTrabajo          String // "Personal para tareas generales", "Asistencia y cuidado de personas"
  domicilioLaboral     String?
  horasSemanales       String? // "Menos de 12 horas", "De 12 a menos de 16 horas", "Desde 16 a más h"
  condicion            String   @default("Activo") // "Activo", "Baja"
  obraSocial           String?
  fechaNacimiento      String? // dd/mm/yyyy
  fechaIngreso         String? // dd/mm/yyyy
  modalidadPago        String? // "Diaria", "Mensual"
  modalidadTrabajo     String? // "Con retiro para distintos empleadores", "Con retiro para un solo empleador", "Sin retiro"
  remuneracionPactada  Decimal? @db.Decimal(12, 2)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  receipts DomesticReceipt[]

  @@unique([userId, fiscalYear, cuil])
  @@index([userId, fiscalYear])
}

model DomesticReceipt {
  id                   String        @id @default(cuid())
  userId               String
  domesticWorkerId     String?
  fiscalYear           Int
  fiscalMonth          Int // 1-12
  periodo              String // "Febrero 2026"
  categoriaProfesional String?
  modalidadPrestacion  String?
  horasSemanales       String?
  modalidadLiquidacion String?
  totalHorasTrabajadas String?
  basico               Decimal?      @db.Decimal(12, 2)
  antiguedad           Decimal?      @db.Decimal(12, 2)
  viaticos             Decimal?      @db.Decimal(12, 2)
  presentismo          Decimal?      @db.Decimal(12, 2)
  otros                Decimal?      @db.Decimal(12, 2)
  total                Decimal       @db.Decimal(12, 2) // Total salary (retribución)
  paymentDetails       Json?         // Array of { tipoPago, importe, fechaPago } from ARCA's "Detalle del Pago"
  contributionAmount   Decimal?      @db.Decimal(12, 2) // APORTES + CONTRIBUCIONES (for SiRADIG)
  contributionDate     String?       // Payment date for contributions (dd/mm/yyyy)
  source               InvoiceSource @default(MANUAL)
  ocrConfidence        Float?
  siradiqStatus        SiradiqStatus @default(PENDING)
  originalFilename     String?
  fileData             Bytes?
  fileMimeType         String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  domesticWorker  DomesticWorker? @relation(fields: [domesticWorkerId], references: [id], onDelete: SetNull)
  automationJobs  AutomationJob[]

  @@unique([userId, domesticWorkerId, fiscalYear, fiscalMonth])
  @@index([userId, fiscalYear])
  @@index([userId, siradiqStatus])
}

// ─── Presentaciones (SiRADIG Form Submissions) ─────────────

model Presentacion {
  id               String             @id @default(cuid())
  userId           String
  fiscalYear       Int
  numero           Int // Presentación number (1, 2, 3...)
  descripcion      String // "Original", "Rectificativa 1", etc.
  fechaEnvio       DateTime // Submission date
  fechaLectura     DateTime? // Employer read date (nullable)
  montoTotal       Decimal?           @db.Decimal(12, 2) // Total deductions from PDF
  source           PresentacionSource
  siradiqStatus    SiradiqStatus      @default(SUBMITTED)
  fileData         Bytes? // PDF file
  fileMimeType     String?
  originalFilename String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  automationJobs AutomationJob[]

  @@unique([userId, fiscalYear, numero])
  @@index([userId, fiscalYear])
}

enum PresentacionSource {
  ARCA_IMPORT
  AUTOMATION
}

// ─── Subscriptions ─────────────────────────────────────────

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  plan                   SubscriptionPlan
  status                 SubscriptionStatus
  billingFrequency       BillingFrequency?
  trialStartDate         DateTime?
  trialEndDate           DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  mercadoPagoPreapprovalId String?          @unique
  trialReminder7DaySentAt  DateTime?
  trialReminder1DaySentAt  DateTime?
  cancelledAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SubscriptionPlan {
  PERSONAL
  FOUNDERS
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  CANCELLED
  PAST_DUE
  EXPIRED
}

enum BillingFrequency {
  MONTHLY
  ANNUAL
}
